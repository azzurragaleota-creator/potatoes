<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quale Patata? 🥔 — Campania Patate</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    :root {
      --green-dark:  #1B3D2C;
      --green-mid:   #2C5F44;
      --green-light: #4A9068;
      --green-pale:  #D4EDE0;
      --potato:      #8B5E3C;
      --potato-gold: #C9922A;
      --gold-light:  #F0C84A;
      --cream:       #FDF7EE;
      --warm-bg:     #FEFCF8;
      --text-dark:   #1A2E22;
      --text-mid:    #3D5A47;
      --shadow:      rgba(30,61,47,.12);
      --r:           16px;
      --rl:          24px;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Nunito', sans-serif;
      background: var(--warm-bg);
      color: var(--text-dark);
      min-height: 100vh;
    }

    /* ── HEADER ────────────────────────────────────── */
    .header {
      background: linear-gradient(135deg, var(--green-dark) 0%, var(--green-mid) 100%);
      padding: 14px 20px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky; top: 0; z-index: 50;
      box-shadow: 0 2px 12px rgba(0,0,0,.25);
    }
    .header-logo { height: 44px; }
    .header-badge {
      font-size: .75rem; font-weight: 700;
      color: rgba(255,255,255,.65);
      letter-spacing: .03em;
    }

    /* ── SCREENS ───────────────────────────────────── */
    .screen { display: none; }
    .screen.active { display: block; animation: fadeUp .35s ease; }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(12px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── HOME ──────────────────────────────────────── */
    .hero {
      background: linear-gradient(150deg, var(--green-dark) 0%, var(--green-mid) 55%, var(--green-light) 100%);
      padding: 56px 24px 72px;
      text-align: center;
      color: white;
    }
    .hero-potato {
      font-size: 84px;
      display: block;
      margin-bottom: 14px;
      animation: bounce 2.4s ease-in-out infinite;
      filter: drop-shadow(0 6px 12px rgba(0,0,0,.3));
    }
    @keyframes bounce {
      0%,100% { transform: translateY(0) rotate(-3deg); }
      50%      { transform: translateY(-14px) rotate(3deg); }
    }
    .hero h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2rem, 6vw, 2.8rem);
      line-height: 1.15;
      margin-bottom: 12px;
    }
    .hero p {
      font-size: 1.05rem;
      opacity: .85;
      max-width: 380px;
      margin: 0 auto;
      line-height: 1.6;
    }

    .mode-cards {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
      padding: 28px 20px;
      max-width: 560px;
      margin: 0 auto;
    }
    .mode-card {
      background: white;
      border-radius: var(--rl);
      padding: 28px 16px;
      text-align: center;
      cursor: pointer;
      border: 2px solid transparent;
      box-shadow: 0 4px 20px var(--shadow);
      transition: all .22s ease;
      user-select: none;
    }
    .mode-card:hover, .mode-card:active {
      transform: translateY(-4px);
      border-color: var(--green-light);
      box-shadow: 0 10px 32px var(--shadow);
    }
    .mode-card .mc-icon { font-size: 52px; display: block; margin-bottom: 12px; }
    .mode-card h2 {
      font-family: 'Playfair Display', serif;
      font-size: 1.05rem;
      color: var(--green-dark);
      margin-bottom: 6px;
    }
    .mode-card p { font-size: .8rem; color: var(--text-mid); line-height: 1.4; }

    .section-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.25rem;
      color: var(--green-dark);
      text-align: center;
      margin-bottom: 14px;
    }
    .variety-section {
      padding: 0 20px 48px;
      max-width: 560px;
      margin: 0 auto;
    }
    .variety-chips { display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; }
    .v-chip {
      padding: 9px 18px;
      border-radius: 999px;
      font-weight: 800;
      font-size: .85rem;
      cursor: pointer;
      transition: all .18s ease;
      border: 2px solid transparent;
    }
    .v-chip:hover { transform: scale(1.06); filter: brightness(.95); }

    /* ── SUB-HEADER (back row) ─────────────────────── */
    .sub-header {
      background: var(--green-dark);
      padding: 16px 20px;
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .back-btn {
      background: none; border: none;
      color: white; font-size: 1.5rem;
      cursor: pointer; line-height: 1;
      padding: 2px 6px;
      border-radius: 8px;
      transition: background .15s;
    }
    .back-btn:hover { background: rgba(255,255,255,.15); }
    .sub-header h2 {
      font-family: 'Playfair Display', serif;
      color: white; font-size: 1.25rem;
    }

    /* ── FINDER ────────────────────────────────────── */
    .dish-intro {
      text-align: center;
      padding: 20px 20px 4px;
      color: var(--text-mid);
      font-size: .95rem;
    }
    .dish-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      padding: 16px 20px 40px;
      max-width: 480px;
      margin: 0 auto;
    }
    .dish-card {
      background: white;
      border-radius: var(--r);
      padding: 18px 8px 14px;
      text-align: center;
      cursor: pointer;
      border: 2px solid transparent;
      box-shadow: 0 2px 12px var(--shadow);
      transition: all .2s ease;
      user-select: none;
    }
    .dish-card:hover, .dish-card:active {
      transform: translateY(-3px);
      border-color: var(--potato-gold);
      box-shadow: 0 6px 24px var(--shadow);
    }
    .dish-card .d-emoji { font-size: 38px; display: block; margin-bottom: 8px; }
    .dish-card .d-name  { font-size: .72rem; font-weight: 800; color: var(--green-dark); line-height: 1.2; }

    /* ── SLOT OVERLAY ──────────────────────────────── */
    .slot-overlay {
      position: fixed; inset: 0;
      background: rgba(20,50,35,.93);
      display: flex; align-items: center; justify-content: center;
      z-index: 200;
      opacity: 0; pointer-events: none;
      transition: opacity .3s ease;
    }
    .slot-overlay.show { opacity: 1; pointer-events: all; }

    .slot-box {
      background: var(--cream);
      border-radius: var(--rl);
      padding: 32px 28px 28px;
      text-align: center;
      width: min(340px, 92vw);
      box-shadow: 0 24px 60px rgba(0,0,0,.4);
    }
    .slot-box-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.2rem;
      color: var(--green-dark);
      margin-bottom: 4px;
    }
    .slot-box-dish { font-size: .9rem; color: var(--text-mid); margin-bottom: 20px; }

    .slot-window {
      height: 120px;
      overflow: hidden;
      border-radius: 14px;
      background: var(--green-dark);
      border: 3px solid var(--gold-light);
      position: relative;
      margin-bottom: 20px;
    }
    .slot-window::before, .slot-window::after {
      content: '';
      position: absolute; left: 0; right: 0; height: 34px; z-index: 2;
      pointer-events: none;
    }
    .slot-window::before { top: 0; background: linear-gradient(to bottom, var(--green-dark), transparent); }
    .slot-window::after  { bottom: 0; background: linear-gradient(to top, var(--green-dark), transparent); }

    .slot-reel { display: flex; flex-direction: column; }
    .slot-item {
      height: 120px; flex-shrink: 0;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
    }
    .slot-item .si-emoji { font-size: 42px; }
    .slot-item .si-name  { font-weight: 900; color: white; font-size: .9rem; margin-top: 4px; }

    .slot-msg {
      font-size: .88rem;
      color: var(--text-mid);
      min-height: 1.4em;
      font-weight: 700;
    }

    /* ── RESULT ────────────────────────────────────── */
    .result-hero {
      padding: 48px 24px 56px;
      text-align: center;
      color: white;
    }
    .result-emoji { font-size: 76px; display: block; margin-bottom: 14px; filter: drop-shadow(0 4px 10px rgba(0,0,0,.3)); }
    .result-badge {
      display: inline-block;
      background: rgba(255,255,255,.22);
      border: 1px solid rgba(255,255,255,.4);
      border-radius: 999px;
      padding: 4px 16px;
      font-size: .78rem;
      font-weight: 800;
      letter-spacing: .04em;
      margin-bottom: 12px;
    }
    .result-name { font-family: 'Playfair Display', serif; font-size: 2.3rem; margin-bottom: 8px; }
    .result-tagline { font-size: 1rem; opacity: .85; }

    .result-content {
      padding: 20px 20px 48px;
      max-width: 500px;
      margin: 0 auto;
    }
    .r-card {
      background: white;
      border-radius: var(--r);
      padding: 22px;
      margin-bottom: 14px;
      box-shadow: 0 4px 20px var(--shadow);
    }
    .r-card h3 {
      font-family: 'Playfair Display', serif;
      color: var(--green-dark);
      margin-bottom: 10px;
      font-size: 1.05rem;
    }
    .r-card p { color: var(--text-mid); line-height: 1.65; font-size: .93rem; }
    .r-tip { background: var(--green-pale); border-left: 4px solid var(--green-light); }
    .r-tip h3 { color: var(--green-dark); }

    .ideal-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 10px; }
    .ideal-tag {
      background: var(--green-pale);
      color: var(--green-dark);
      border-radius: 999px;
      padding: 4px 13px;
      font-size: .78rem;
      font-weight: 800;
    }

    .result-actions { display: flex; gap: 12px; margin-top: 4px; }
    .btn { flex: 1; border-radius: var(--r); padding: 15px; font-family: 'Nunito', sans-serif; font-size: .95rem; font-weight: 800; cursor: pointer; transition: all .2s ease; border: none; }
    .btn-green { background: var(--green-mid); color: white; }
    .btn-green:hover { background: var(--green-dark); transform: translateY(-2px); }
    .btn-outline { background: transparent; color: var(--green-mid); border: 2px solid var(--green-mid); }
    .btn-outline:hover { background: var(--green-pale); }

    /* ── QUIZ ──────────────────────────────────────── */
    .quiz-topbar {
      background: var(--green-dark);
      padding: 14px 20px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .quiz-score-display { font-weight: 900; font-size: 1.05rem; color: var(--gold-light); }
    .quiz-q-counter { font-size: .82rem; color: rgba(255,255,255,.65); font-weight: 700; }
    .progress-bar { height: 5px; background: rgba(255,255,255,.15); }
    .progress-fill { height: 100%; background: var(--gold-light); transition: width .35s ease; }

    .quiz-body {
      padding: 28px 20px 48px;
      max-width: 500px;
      margin: 0 auto;
      text-align: center;
    }
    .quiz-dish-emoji { font-size: 72px; display: block; margin-bottom: 16px; }
    .quiz-q-text { font-family: 'Playfair Display', serif; font-size: 1.35rem; color: var(--green-dark); margin-bottom: 6px; line-height: 1.3; }
    .quiz-dish-label { font-size: 1.05rem; color: var(--text-mid); margin-bottom: 28px; font-weight: 700; }

    .quiz-options { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .q-opt {
      background: white;
      border: 2px solid #DDE8E2;
      border-radius: var(--r);
      padding: 20px 10px;
      text-align: center;
      cursor: pointer;
      transition: all .18s ease;
      box-shadow: 0 2px 12px var(--shadow);
      user-select: none;
    }
    .q-opt:hover:not(.disabled) { border-color: var(--potato-gold); transform: translateY(-2px); }
    .q-opt .qo-emoji { font-size: 34px; display: block; margin-bottom: 8px; }
    .q-opt .qo-name  { font-weight: 900; font-size: .88rem; color: var(--green-dark); display: block; }
    .q-opt .qo-type  { font-size: .72rem; color: var(--text-mid); }
    .q-opt.correct { background: #D4EDDA; border-color: #28A745; animation: pop .35s ease; }
    .q-opt.wrong   { background: #F8D7DA; border-color: #DC3545; animation: shake .35s ease; }
    .q-opt.disabled { pointer-events: none; }

    @keyframes pop   { 0%{transform:scale(1)} 50%{transform:scale(1.05)} 100%{transform:scale(1)} }
    @keyframes shake { 0%,100%{transform:translateX(0)} 30%{transform:translateX(-7px)} 70%{transform:translateX(7px)} }

    .quiz-feedback {
      margin-top: 18px;
      padding: 14px 16px;
      border-radius: var(--r);
      font-size: .88rem;
      font-weight: 700;
      line-height: 1.5;
      display: none;
      text-align: left;
    }
    .quiz-feedback.show { display: block; }
    .fb-ok  { background: #D4EDDA; color: #155724; }
    .fb-err { background: #F8D7DA; color: #721C24; }

    /* QUIZ END */
    .quiz-end { padding: 48px 24px; text-align: center; max-width: 500px; margin: 0 auto; }
    .qe-emoji { font-size: 88px; display: block; margin-bottom: 16px; }
    .qe-title { font-family: 'Playfair Display', serif; font-size: 2rem; color: var(--green-dark); margin-bottom: 10px; }
    .qe-score { font-size: 3.2rem; font-weight: 900; color: var(--potato-gold); margin: 14px 0; }
    .qe-msg { color: var(--text-mid); font-size: 1rem; line-height: 1.6; margin-bottom: 28px; }
    .qe-actions { display: flex; gap: 12px; }

    /* ── CONFETTI ───────────────────────────────────── */
    #confetti { position: fixed; inset: 0; pointer-events: none; overflow: hidden; z-index: 300; }
    .cp {
      position: absolute; top: -12px;
      border-radius: 3px;
      animation: fall linear forwards;
    }
    @keyframes fall { to { transform: translateY(105vh) rotate(720deg); opacity: 0; } }

    /* ── FOOTER ────────────────────────────────────── */
    .footer {
      background: var(--green-dark);
      padding: 24px;
      text-align: center;
      color: rgba(255,255,255,.5);
      font-size: .8rem;
      line-height: 1.8;
    }
    .footer a { color: var(--green-pale); text-decoration: none; }
    .footer a:hover { text-decoration: underline; }

    /* ── RESPONSIVE ────────────────────────────────── */
    @media (max-width: 360px) {
      .mode-cards { grid-template-columns: 1fr; }
    }
    @media (min-width: 600px) {
      .dish-grid { grid-template-columns: repeat(4, 1fr); }
    }
  </style>
</head>
<body>

<div id="confetti"></div>

<!-- HEADER -->
<header class="header">
  <img src="https://www.campaniapatate.com/wp-content/uploads/2026/01/campania-patate-logo-white.svg"
       alt="Campania Patate" class="header-logo"
       onerror="this.outerHTML='<span style=\'color:white;font-family:serif;font-weight:700;font-size:1.1rem\'>🥔 Campania Patate</span>'">
  <span class="header-badge">🎮 Il Gioco delle Patate</span>
</header>

<!-- ═══════════════════════════════ HOME ════════════════════════════════ -->
<div id="s-home" class="screen active">
  <div class="hero">
    <span class="hero-potato">🥔</span>
    <h1>Noi non siamo<br>tutte uguali!</h1>
    <p>Scopri quale varietà Campania Patate è perfetta per il tuo piatto preferito</p>
  </div>

  <div class="mode-cards">
    <div class="mode-card" onclick="goto('s-finder')">
      <span class="mc-icon">🍳</span>
      <h2>Ho una ricetta</h2>
      <p>Scegli un piatto e scopri la patata giusta con la slot machine!</p>
    </div>
    <div class="mode-card" onclick="startQuiz()">
      <span class="mc-icon">👨‍🍳</span>
      <h2>Sfida Chef</h2>
      <p>Metti alla prova le tue conoscenze sulle nostre patate</p>
    </div>
  </div>

  <div class="variety-section">
    <p class="section-title">Le nostre varietà</p>
    <div class="variety-chips" id="vchips"></div>
  </div>
</div>

<!-- ═══════════════════════════════ FINDER ══════════════════════════════ -->
<div id="s-finder" class="screen">
  <div class="sub-header">
    <button class="back-btn" onclick="goto('s-home')">←</button>
    <h2>Cosa vuoi preparare?</h2>
  </div>
  <p class="dish-intro">Tocca un piatto per scoprire la patata perfetta 👇</p>
  <div class="dish-grid" id="dishGrid"></div>
</div>

<!-- ═══════════════════════════════ RESULT ══════════════════════════════ -->
<div id="s-result" class="screen">
  <div class="sub-header">
    <button class="back-btn" id="resultBack">←</button>
    <h2>Ecco la tua patata!</h2>
  </div>
  <div id="resultHero" class="result-hero"></div>
  <div id="resultContent" class="result-content"></div>
</div>

<!-- ═══════════════════════════════ QUIZ ════════════════════════════════ -->
<div id="s-quiz" class="screen">
  <div class="quiz-topbar">
    <button class="back-btn" onclick="goto('s-home')">←</button>
    <div class="quiz-score-display">⭐ <span id="qScore">0</span> punti</div>
    <div class="quiz-q-counter"><span id="qNum">1</span>/<span id="qTot">8</span></div>
  </div>
  <div class="progress-bar"><div class="progress-fill" id="qProg" style="width:0%"></div></div>
  <div id="quizBody"></div>
</div>

<!-- ═══════════════════════════════ SLOT OVERLAY ════════════════════════ -->
<div class="slot-overlay" id="slotOverlay">
  <div class="slot-box">
    <div class="slot-box-title">🎰 La slot sta girando…</div>
    <div class="slot-box-dish" id="slotLabel"></div>
    <div class="slot-window">
      <div class="slot-reel" id="slotReel"></div>
    </div>
    <div class="slot-msg" id="slotMsg">Sto cercando la patata giusta…</div>
  </div>
</div>

<footer class="footer">
  <div>🥔 <strong style="color:rgba(255,255,255,.8)">Campania Patate</strong></div>
  <div><a href="https://www.campaniapatate.com" target="_blank">www.campaniapatate.com</a></div>
  <div style="margin-top:6px">Le migliori patate della Campania, dalla terra alla tua tavola</div>
</footer>

<script>
// ══════════════════════════════════════════════════════════════
//  DATA
// ══════════════════════════════════════════════════════════════
const V = {
  crock4all: {
