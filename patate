// ══════════════════════════════════════════════════════════════
//  NAVIGATION
// ══════════════════════════════════════════════════════════════
let fromScreen = 's-home';

function goto(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  window.scrollTo({top: 0, behavior: 'smooth'});
}

// ══════════════════════════════════════════════════════════════
//  INIT HOME chips
// ══════════════════════════════════════════════════════════════
(function initHome() {
  const c = document.getElementById('vchips');
  Object.values(V).forEach(v => {
    const el = document.createElement('div');
    el.className = 'v-chip';
    el.style.background = v.pale;
    el.style.color = v.color;
    el.innerHTML = `${v.emoji} ${v.name}`;
    el.onclick = () => showResult(v.id, 's-home');
    c.appendChild(el);
  });
})();

// ══════════════════════════════════════════════════════════════
//  INIT FINDER
// ══════════════════════════════════════════════════════════════
(function initFinder() {
  const g = document.getElementById('dishGrid');
  DISHES.forEach(d => {
    const el = document.createElement('div');
    el.className = 'dish-card';
    el.innerHTML = `<span class="d-emoji">${d.emoji}</span><span class="d-name">${d.name}</span>`;
    el.onclick = () => runSlot(d);
    g.appendChild(el);
  });
})();

// ══════════════════════════════════════════════════════════════
//  SLOT MACHINE
// ══════════════════════════════════════════════════════════════
function runSlot(dish) {
  const overlay = document.getElementById('slotOverlay');
  const reel    = document.getElementById('slotReel');
  const label   = document.getElementById('slotLabel');
  const msg     = document.getElementById('slotMsg');

  label.textContent = `${dish.emoji} ${dish.name}`;
  msg.textContent   = 'Sto cercando la patata giusta…';

  // Build sequence: 3 random shuffles of all varieties + winner at end
  const all = Object.values(V);
  const winner = V[dish.v];
  const seq = [];
  for (let i = 0; i < 3; i++) {
    [...all].sort(() => Math.random() - .5).forEach(v => seq.push(v));
  }
  seq.push(winner); // winner always last

  reel.innerHTML = seq.map(v =>
    `<div class="slot-item">
       <span class="si-emoji">${v.emoji}</span>
       <span class="si-name">${v.name}</span>
     </div>`
  ).join('');

  // Reset
  reel.style.transition = 'none';
  reel.style.transform  = 'translateY(0)';
  overlay.classList.add('show');

  // Animate to last item
  const itemH = 120;
  const targetY = -((seq.length - 1) * itemH);
  const duration = 2.2; // seconds

  requestAnimationFrame(() => requestAnimationFrame(() => {
    reel.style.transition = `transform ${duration}s cubic-bezier(.15,.55,.45,1)`;
    reel.style.transform  = `translateY(${targetY}px)`;
  }));

  setTimeout(() => {
    msg.textContent = `✅ Eccola: ${winner.name}!`;
    setTimeout(() => {
      overlay.classList.remove('show');
      showResult(dish.v, 's-finder', dish);
    }, 900);
  }, duration * 1000 + 100);
}

// ══════════════════════════════════════════════════════════════
//  RESULT SCREEN
// ══════════════════════════════════════════════════════════════
function showResult(vid, back, dish = null) {
  const v = V[vid];
  fromScreen = back;
  document.getElementById('resultBack').onclick = () => goto(back);

  document.getElementById('resultHero').style.background =
    `linear-gradient(135deg, ${v.color}dd 0%, ${v.color}99 100%)`;

  document.getElementById('resultHero').innerHTML = `
    <span class="result-emoji">${v.emoji}</span>
    <div class="result-badge">${v.type}</div>
    <div class="result-name">${v.name}</div>
    <div class="result-tagline">${v.tagline}</div>
  `;

  const dishBlock = dish ? `
    <div class="r-card" style="border-left:4px solid ${v.color};background:${v.pale}">
      <h3>${dish.emoji} Perché per ${dish.name}?</h3>
      <p>${dish.why}</p>
    </div>` : '';

  document.getElementById('resultContent').innerHTML = `
    ${dishBlock}
    <div class="r-card">
      <h3>📖 Descrizione</h3>
      <p>${v.desc}</p>
    </div>
    <div class="r-card r-tip">
      <h3>💡 Lo sapevi?</h3>
      <p>${v.tip}</p>
    </div>
    <div class="r-card">
      <h3>✅ Ideale per</h3>
      <div class="ideal-tags">
        ${v.for.map(f => `<span class="ideal-tag">${f}</span>`).join('')}
      </div>
    </div>
    <div class="result-actions">
      <button class="btn btn-green" onclick="goto('s-finder')">🍳 Cerca altro piatto</button>
      <button class="btn btn-outline" onclick="startQuiz()">🏆 Sfida Chef</button>
    </div>
  `;

  goto('s-result');
}

// ══════════════════════════════════════════════════════════════
//  QUIZ
// ══════════════════════════════════════════════════════════════
const TOTAL = 8;
let qQuestions = [], qIdx = 0, qScore = 0;

function startQuiz() {
  qQuestions = [...DISHES].sort(() => Math.random() - .5).slice(0, TOTAL);
  qIdx = 0; qScore = 0;
  document.getElementById('qScore').textContent = 0;
  document.getElementById('qTot').textContent = TOTAL;
  document.getElementById('qProg').style.width = '0%';
  goto('s-quiz');
  renderQ();
}

function renderQ() {
  document.getElementById('qProg').style.width = `${(qIdx / TOTAL) * 100}%`;
  document.getElementById('qNum').textContent  = Math.min(qIdx + 1, TOTAL);

  if (qIdx >= TOTAL) { showQuizEnd(); return; }

  const dish = qQuestions[qIdx];
  const opts = Object.values(V).sort(() => Math.random() - .5);

  document.getElementById('quizBody').innerHTML = `
    <div class="quiz-body">
      <span class="quiz-dish-emoji">${dish.emoji}</span>
      <div class="quiz-q-text">Quale patata sceglieresti per…</div>
      <div class="quiz-dish-label">"${dish.name}"?</div>
      <div class="quiz-options">
        ${opts.map(v => `
          <div class="q-opt" data-vid="${v.id}" onclick="pickOpt(this,'${dish.v}','${dish.id}')">
            <span class="qo-emoji">${v.emoji}</span>
            <span class="qo-name">${v.name}</span>
            <span class="qo-type">${v.type.split('•')[0].trim()}</span>
          </div>`).join('')}
      </div>
      <div class="quiz-feedback" id="qFeed"></div>
    </div>
  `;
}

function pickOpt(el, correct, dishId) {
  document.querySelectorAll('.q-opt').forEach(o => o.classList.add('disabled'));
  const selected = el.dataset.vid;
  const ok = selected === correct;
  const dish = DISHES.find(d => d.id === dishId);

  el.classList.add(ok ? 'correct' : 'wrong');
  if (!ok) {
    document.querySelectorAll('.q-opt').forEach(o => {
      if (o.dataset.vid === correct) o.classList.add('correct');
    });
  }

  if (ok) { qScore++; document.getElementById('qScore').textContent = qScore; confetti(8); }

  const feed = document.getElementById('qFeed');
  feed.className = `quiz-feedback show ${ok ? 'fb-ok' : 'fb-err'}`;
  feed.textContent = ok
    ? `✅ Perfetto! ${dish.why}`
    : `❌ Quasi! La risposta giusta era ${V[correct].name}. ${dish.why}`;

  qIdx++;
  setTimeout(renderQ, 2400);
}

function showQuizEnd() {
  const pct = Math.round((qScore / TOTAL) * 100);
  let emoji, msg;
  if (pct === 100) { emoji='🏆'; msg='Perfetto! Sei un vero esperto di patate campane!'; confetti(40); }
  else if (pct >= 75) { emoji='🌟'; msg='Ottimo! Conosci bene le nostre varietà!'; confetti(20); }
  else if (pct >= 50) { emoji='👨‍🍳'; msg='Buona base! Riprova per diventare chef delle patate.'; }
  else               { emoji='🥔'; msg='Le patate hanno ancora qualcosa da insegnarti… riprova!'; }

  document.getElementById('quizBody').innerHTML = `
    <div class="quiz-end">
      <span class="qe-emoji">${emoji}</span>
      <div class="qe-title">Quiz completato!</div>
      <div class="qe-score">${qScore}/${TOTAL}</div>
      <div class="qe-msg">${msg}</div>
      <div class="qe-actions">
        <button class="btn btn-green" onclick="startQuiz()">🔄 Rigioca</button>
        <button class="btn btn-outline" onclick="goto('s-home')">🏠 Home</button>
      </div>
    </div>
  `;
  document.getElementById('qProg').style.width = '100%';
}

// ══════════════════════════════════════════════════════════════
//  CONFETTI
// ══════════════════════════════════════════════════════════════
function confetti(n) {
  const c = document.getElementById('confetti');
  const cols = ['#2D6A4F','#C9922A','#F0C84A','#4A9068','#8B5E3C','#FFD700','#E8503A'];
  for (let i = 0; i < n; i++) {
    const el = document.createElement('div');
    el.className = 'cp';
    const size = 7 + Math.random() * 8;
    el.style.cssText = `
      left:${Math.random()*100}vw;
      width:${size}px; height:${size}px;
      background:${cols[Math.floor(Math.random()*cols.length)]};
      border-radius:${Math.random()>.5?'50%':'3px'};
      animation-duration:${1.4+Math.random()*1.8}s;
      animation-delay:${Math.random()*0.4}s;
    `;
    c.appendChild(el);
    el.addEventListener('animationend', () => el.remove());
  }
}
